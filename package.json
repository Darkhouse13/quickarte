{
  "name": "quickarte-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "turbo run dev --filter=@quickarte/qr-menu",
    "build": "turbo run build",
    "start": "pnpm --filter @quickarte/qr-menu start",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:http-status": "pnpm --filter @quickarte/qr-menu test:http-status",
    "sdk:generate": "pnpm --filter @quickarte/api openapi:generate && pnpm --filter @quickarte/shared-types sdk:generate",
    "db:generate": "pnpm --filter @quickarte/qr-menu db:generate",
    "db:migrate": "pnpm --filter @quickarte/qr-menu db:migrate",
    "db:migrate:prod": "pnpm --filter @quickarte/qr-menu db:migrate:prod",
    "db:push": "pnpm --filter @quickarte/qr-menu db:push",
    "db:studio": "pnpm --filter @quickarte/qr-menu db:studio",
    "db:seed": "pnpm --filter @quickarte/qr-menu db:seed",
    "db:seed:permissions": "pnpm --filter @quickarte/db-schema db:seed:permissions"
  },
  "devDependencies": {
    "turbo": "^2.5.6"
  },
  "pnpm": {
    "overrides": {
      "vite": "7.3.2"
    }
  }
}
