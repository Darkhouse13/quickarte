DATABASE_URL=postgresql://quickarte:quickarte@localhost:5433/quickarte
BETTER_AUTH_SECRET=change-me-to-random-32-chars
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Canonical public URL used in third-party integrations (Stripe business_profile.url,
# email links, webhook return URLs, OAuth callbacks). Must be publicly reachable.
# In local dev, leave as-is — Stripe and similar services reject localhost.
NEXT_PUBLIC_CANONICAL_URL=https://quickarte.fr

# Sales contact target for the UpsellCard CTA on gated modules.
# Accepts a bare email, a phone, mailto:/tel:/https: URLs, or a WhatsApp link.
NEXT_PUBLIC_SALES_CONTACT=mailto:hello@quickarte.fr

# Comma-separated allowlist of admin emails for entitlement server actions.
# CLI script bypasses this; only the in-app server actions enforce it.
QUICKARTE_ADMIN_EMAILS=

# ─── Stripe Connect (platform → merchant marketplace payments) ───
# Test-mode keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Paste whatever `stripe listen --forward-to ...` prints on startup:
STRIPE_WEBHOOK_SECRET=whsec_...
# Optional: only needed if we ever move from Express to Standard OAuth.
STRIPE_CONNECT_CLIENT_ID=
# Platform fee in basis points, applied to every order via Stripe Connect.
# Quickarte's current pricing model is a flat monthly subscription (billed separately),
# NOT a per-transaction percentage. Leave this at 0.
QUICKARTE_PLATFORM_FEE_BPS=0

# ─── Web Push (merchant order notifications) ───
# Generate a pair with: `npm run push -- vapid` (or `npx web-push generate-vapid-keys`)
# and paste the output below. Without these, push sends silently no-op.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@quickarte.fr

# Optional dev escape hatch: register the service worker even in `next dev`.
# Off by default — dev-time caching is a debugging nightmare.
NEXT_PUBLIC_ENABLE_SW_IN_DEV=false

# ─── Transactional email (Resend) ───
# Used by the landing-page contact form to alert the Quickarte team.
# If RESEND_API_KEY is empty, contact submissions are still saved to the DB,
# but no email is sent.
RESEND_API_KEY=
CONTACT_EMAIL_FROM=Quickarte <bonjour@quickarte.fr>

# ─── Sentry (error reporting) ───
# DSN for both server and browser. Paste from sentry.io → project → Client Keys.
# In dev, leave blank — Sentry is disabled unless NODE_ENV=production.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Auth token for source-map upload at build time. Generate at
# https://sentry.io/settings/account/api/auth-tokens/ with scope
# `project:releases` + `org:read`. Optional in dev.
SENTRY_AUTH_TOKEN=
