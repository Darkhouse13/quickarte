{
  "expo": {
    "name": "Quickarte POS Terminal",
    "slug": "quickarte-pos-terminal",
    "scheme": "quickarte-pos-terminal",
    "version": "0.1.0",
    "orientation": "default",
    "platforms": ["ios", "android", "web"],
    "ios": {
      "bundleIdentifier": "ma.quickarte.posterminal",
      "supportsTablet": true
    },
    "android": {
      "package": "ma.quickarte.posterminal"
    },
    "plugins": ["expo-router", "expo-secure-store", "expo-localization"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
