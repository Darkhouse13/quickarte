{
  "name": "@quickarte/pos-terminal",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "dev:ios": "expo start --ios",
    "dev:android": "expo start --android",
    "dev:web": "expo start --web",
    "build": "expo export --platform android",
    "lint": "eslint .",
    "test": "jest --runInBand",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@nozbe/watermelondb": "0.28.0",
    "@quickarte/i18n": "workspace:*",
    "@quickarte/shared-types": "workspace:*",
    "@react-native-community/netinfo": "11.5.2",
    "expo": "55.0.24",
    "expo-constants": "55.0.16",
    "expo-linking": "55.0.15",
    "expo-localization": "55.0.14",
    "expo-router": "55.0.14",
    "expo-secure-store": "55.0.14",
    "expo-sqlite": "55.0.16",
    "i18next": "25.7.2",
    "i18next-icu": "2.4.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-i18next": "16.5.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "4.23.0",
    "react-native-web": "0.21.2",
    "zustand": "5.0.13"
  },
  "devDependencies": {
    "@quickarte/config": "workspace:*",
    "@testing-library/react-native": "13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "19.2.10",
    "babel-jest": "29.7.0",
    "eslint": "^9.39.1",
    "jest": "29.7.0",
    "jest-expo": "55.0.17",
    "typescript": "5.9.2"
  },
  "jest": {
    "preset": "jest-expo",
    "testMatch": [
      "<rootDir>/src/**/*.test.ts"
    ]
  }
}
