{
  "name": "@quickarte/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "pnpm --filter @quickarte/db-schema build",
    "dev": "nest start --watch",
    "prebuild": "pnpm --filter @quickarte/db-schema build",
    "build": "nest build",
    "start": "node dist/src/main.js",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --tsconfig tsconfig.json --test src/**/*.test.ts test/**/*.test.ts",
    "openapi:generate": "tsx --tsconfig tsconfig.json scripts/generate-openapi.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.21",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.21",
    "@nestjs/platform-express": "^11.1.21",
    "@nestjs/swagger": "^11.4.3",
    "@quickarte/db-schema": "workspace:*",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "drizzle-orm": "0.45.2",
    "nestjs-pino": "^4.6.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/testing": "^11.1.21",
    "@quickarte/config": "workspace:*",
    "@types/express": "^5.0.6",
    "@types/node": "^25.8.0",
    "@types/pg": "^8.20.0",
    "eslint": "^9.39.1",
    "tsx": "^4.22.0",
    "typescript": "5.6.3"
  }
}
