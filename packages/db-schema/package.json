{
  "name": "@quickarte/db-schema",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./dist/index.js"
    },
    "./migrations": {
      "types": "./src/migrations.ts",
      "import": "./src/migrations.ts",
      "require": "./dist/migrations.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "db:push": "drizzle-kit push --config drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config drizzle.config.ts",
    "test": "tsx --test migrations/0016_customer_order_access.test.ts migrations/0017_options_variants.test.ts migrations/0018_pos_reconciliation.test.ts migrations/0019_print_station_routing.test.ts migrations/0020_loyalty_credits.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "@quickarte/config": "workspace:*",
    "@types/node": "^25.8.0",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "tsx": "^4.20.6",
    "typescript": "^5.6.3"
  }
}
