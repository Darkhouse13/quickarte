{
  "name": "@quickarte/shared-types",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "sdk:generate": "openapi-typescript openapi.json -o src/api.ts",
    "test": "tsx --test src/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@quickarte/config": "workspace:*",
    "openapi-typescript": "^7.13.0",
    "tsx": "^4.22.0",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "openapi-fetch": "^0.17.0"
  }
}
