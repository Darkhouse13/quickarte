{
  "openapi": "3.1.0",
  "paths": {
    "/v1/health": {
      "get": {
        "operationId": "HealthController_getHealth",
        "parameters": [],
        "responses": {
          "200": {
            "description": "API is healthy and database is reachable.",
            "content": {
              "application/json": {
                "schema": {
                  "example": {
                    "status": "ok",
                    "db": "ok",
                    "timestamp": "2026-05-16T12:00:00.000Z"
                  }
                }
              }
            }
          },
          "503": {
            "description": "API is running but database is not reachable."
          }
        },
        "summary": "Check API and database health",
        "tags": [
          "health"
        ]
      }
    },
    "/v1/auth/staff/pin-login": {
      "post": {
        "operationId": "PinLoginController_login",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "businessId",
                  "pin"
                ],
                "properties": {
                  "businessId": {
                    "type": "string",
                    "format": "uuid"
                  },
                  "pin": {
                    "type": "string",
                    "pattern": "^\\d{4,6}$"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Access and refresh tokens issued.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "accessToken",
                    "refreshToken",
                    "tokenType",
                    "expiresIn"
                  ],
                  "properties": {
                    "accessToken": {
                      "type": "string"
                    },
                    "refreshToken": {
                      "type": "string"
                    },
                    "tokenType": {
                      "type": "string",
                      "enum": [
                        "Bearer"
                      ]
                    },
                    "expiresIn": {
                      "type": "number",
                      "example": 900
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid PIN."
          },
          "429": {
            "description": "Too many PIN attempts."
          }
        },
        "summary": "Staff PIN login",
        "tags": [
          "Auth"
        ]
      }
    },
    "/v1/auth/owner/login": {
      "post": {
        "operationId": "OwnerLoginController_login",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email",
                  "password",
                  "businessSlug"
                ],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "password": {
                    "type": "string",
                    "minLength": 8
                  },
                  "businessSlug": {
                    "type": "string",
                    "example": "cafe-atlas"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Access and refresh tokens issued.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "accessToken",
                    "refreshToken",
                    "tokenType",
                    "expiresIn"
                  ],
                  "properties": {
                    "accessToken": {
                      "type": "string"
                    },
                    "refreshToken": {
                      "type": "string"
                    },
                    "tokenType": {
                      "type": "string",
                      "enum": [
                        "Bearer"
                      ]
                    },
                    "expiresIn": {
                      "type": "number",
                      "example": 900
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials."
          },
          "429": {
            "description": "Too many login attempts."
          }
        },
        "summary": "Owner or manager email/password login",
        "tags": [
          "Auth"
        ]
      }
    },
    "/v1/auth/refresh": {
      "post": {
        "operationId": "RefreshController_refresh",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "refreshToken"
                ],
                "properties": {
                  "refreshToken": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "New access and refresh tokens issued.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "accessToken",
                    "refreshToken",
                    "tokenType",
                    "expiresIn"
                  ],
                  "properties": {
                    "accessToken": {
                      "type": "string"
                    },
                    "refreshToken": {
                      "type": "string"
                    },
                    "tokenType": {
                      "type": "string",
                      "enum": [
                        "Bearer"
                      ]
                    },
                    "expiresIn": {
                      "type": "number",
                      "example": 900
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Refresh token is invalid."
          },
          "429": {
            "description": "Too many refresh attempts."
          }
        },
        "summary": "Rotate a refresh token and issue a new token pair",
        "tags": [
          "Auth"
        ]
      }
    },
    "/v1/audit-log": {
      "get": {
        "operationId": "AuditLogController_list",
        "parameters": [
          {
            "name": "before",
            "required": false,
            "in": "query",
            "schema": {
              "example": "2026-05-16T12:00:00.000Z"
            }
          },
          {
            "name": "limit",
            "required": false,
            "in": "query",
            "schema": {
              "example": 50
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Tenant-scoped audit-log entries."
          }
        },
        "summary": "List audit-log entries for the current tenant",
        "tags": [
          "Audit Log"
        ]
      }
    },
