{
  "openapi": "3.1.0",
  "paths": {
    "/v1/health": {
      "get": {
        "operationId": "HealthController_getHealth",
        "parameters": [],
        "responses": {
          "200": {
            "description": "API is healthy and database is reachable.",
            "content": {
              "application/json": {
                "schema": {
                  "example": {
                    "status": "ok",
                    "db": "ok",
                    "timestamp": "2026-05-16T12:00:00.000Z"
                  }
                }
              }
            }
          },
          "503": {
            "description": "API is running but database is not reachable."
          }
        },
        "summary": "Check API and database health",
        "tags": [
          "health"
        ]
      }
    },
    "/v1/auth/staff/pin-login": {
      "post": {
        "operationId": "PinLoginController_login",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "businessId",
                  "pin"
                ],
                "properties": {
                  "businessId": {
                    "type": "string",
                    "format": "uuid"
                  },
                  "pin": {
                    "type": "string",
                    "pattern": "^\\d{4,6}$"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Access and refresh tokens issued.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "accessToken",
                    "refreshToken",
                    "tokenType",
                    "expiresIn"
                  ],
                  "properties": {
                    "accessToken": {
                      "type": "string"
                    },
                    "refreshToken": {
                      "type": "string"
                    },
                    "tokenType": {
                      "type": "string",
                      "enum": [
                        "Bearer"
                      ]
                    },
                    "expiresIn": {
                      "type": "number",
                      "example": 900
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid PIN."
          },
          "429": {
            "description": "Too many PIN attempts."
          }
        },
        "summary": "Staff PIN login",
        "tags": [
          "Auth"
        ]
      }
    },
    "/v1/auth/owner/login": {
      "post": {
        "operationId": "OwnerLoginController_login",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email",
                  "password",
                  "businessSlug"
                ],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "password": {
                    "type": "string",
                    "minLength": 8
                  },
                  "businessSlug": {
                    "type": "string",
                    "example": "cafe-atlas"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Access and refresh tokens issued.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "accessToken",
                    "refreshToken",
                    "tokenType",
                    "expiresIn"
                  ],
                  "properties": {
                    "accessToken": {
                      "type": "string"
                    },
                    "refreshToken": {
                      "type": "string"
                    },
                    "tokenType": {
                      "type": "string",
                      "enum": [
                        "Bearer"
                      ]
                    },
                    "expiresIn": {
                      "type": "number",
                      "example": 900
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials."
          },
          "429": {
            "description": "Too many login attempts."
          }
        },
        "summary": "Owner or manager email/password login",
        "tags": [
          "Auth"
        ]
      }
    },
    "/v1/auth/refresh": {
      "post": {
        "operationId": "RefreshController_refresh",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "refreshToken"
                ],
                "properties": {
                  "refreshToken": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "New access and refresh tokens issued.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "accessToken",
                    "refreshToken",
                    "tokenType",
                    "expiresIn"
                  ],
                  "properties": {
                    "accessToken": {
                      "type": "string"
                    },
                    "refreshToken": {
                      "type": "string"
                    },
                    "tokenType": {
                      "type": "string",
                      "enum": [
                        "Bearer"
                      ]
                    },
                    "expiresIn": {
                      "type": "number",
                      "example": 900
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Refresh token is invalid."
          },
          "429": {
            "description": "Too many refresh attempts."
          }
        },
        "summary": "Rotate a refresh token and issue a new token pair",
        "tags": [
          "Auth"
        ]
      }
    },
    "/v1/audit-log": {
      "get": {
        "operationId": "AuditLogController_list",
        "parameters": [
          {
            "name": "before",
            "required": false,
            "in": "query",
            "schema": {
              "example": "2026-05-16T12:00:00.000Z"
            }
          },
          {
            "name": "limit",
            "required": false,
            "in": "query",
            "schema": {
              "example": 50
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Tenant-scoped audit-log entries."
          }
        },
        "summary": "List audit-log entries for the current tenant",
        "tags": [
          "Audit Log"
        ]
      }
    },
    "/v1/businesses/me": {
      "get": {
        "operationId": "BusinessesController_getCurrentBusiness",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Current business profile for the tenant context."
          },
          "404": {
            "description": "No business exists for the current tenant context."
          }
        },
        "summary": "Get the current tenant business profile",
        "tags": [
          "Businesses"
        ]
      }
    },
    "/v1/businesses/me/setup": {
      "get": {
        "operationId": "BusinessesSetupController_get",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Business setup profile, legal profile, and default branch."
          }
        },
        "summary": "Get current business setup profile",
        "tags": [
          "Businesses"
        ]
      },
      "patch": {
        "operationId": "BusinessesSetupController_update",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "type": {
                    "type": "string",
                    "enum": [
                      "restaurant",
                      "cafe",
                      "autre"
                    ]
                  },
                  "currency": {
                    "type": "string"
                  },
                  "secondaryCurrency": {
                    "type": "string",
                    "nullable": true
                  },
                  "timezone": {
                    "type": "string"
                  },
                  "locale": {
                    "type": "string"
                  },
                  "logo": {
                    "type": "string",
                    "nullable": true
                  },
                  "legalProfile": {
                    "type": "object",
                    "properties": {
                      "legalName": {
                        "type": "string"
                      },
                      "iceNumber": {
                        "type": "string",
                        "nullable": true,
                        "maxLength": 32
                      },
                      "rcNumber": {
                        "type": "string",
                        "nullable": true,
                        "maxLength": 32
                      },
                      "ifNumber": {
                        "type": "string",
                        "nullable": true,
                        "maxLength": 32
                      },
                      "patenteNumber": {
                        "type": "string",
                        "nullable": true,
                        "maxLength": 32
                      },
                      "cnssNumber": {
                        "type": "string",
                        "nullable": true,
                        "maxLength": 32
                      },
                      "legalAddress": {
                        "type": "string",
                        "nullable": true
                      },
                      "legalCity": {
                        "type": "string",
                        "nullable": true
                      },
                      "legalPostcode": {
                        "type": "string",
                        "nullable": true,
                        "maxLength": 16
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated business setup profile."
          }
        },
        "summary": "Update current business setup profile",
        "tags": [
          "Businesses"
        ]
      }
    },
    "/v1/branches": {
      "get": {
        "operationId": "BranchesController_list",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Tenant branch list."
          }
        },
        "summary": "List branches for the current business",
        "tags": [
          "Branches"
        ]
      },
      "post": {
        "operationId": "BranchesController_create",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "name",
                  "slug"
                ],
                "properties": {
                  "name": {
                    "type": "string",
                    "maxLength": 120
                  },
                  "slug": {
                    "type": "string",
                    "maxLength": 80,
                    "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
                  },
                  "status": {
                    "type": "string",
                    "enum": [
                      "active",
                      "inactive"
                    ]
                  },
                  "addressLine1": {
                    "type": "string",
                    "nullable": true
                  },
                  "addressLine2": {
                    "type": "string",
                    "nullable": true
                  },
                  "city": {
                    "type": "string",
                    "nullable": true
                  },
                  "postcode": {
                    "type": "string",
                    "nullable": true,
                    "maxLength": 16
                  },
                  "countryCode": {
                    "type": "string",
                    "maxLength": 2,
                    "default": "MA"
                  },
                  "googlePlaceId": {
                    "type": "string",
                    "nullable": true
                  },
                  "formattedAddress": {
                    "type": "string",
                    "nullable": true
                  },
                  "lat": {
                    "type": "string",
                    "nullable": true
                  },
                  "lng": {
                    "type": "string",
                    "nullable": true
                  },
                  "phone": {
                    "type": "string",
                    "nullable": true
                  },
                  "email": {
                    "type": "string",
                    "nullable": true,
                    "format": "email"
                  },
                  "website": {
                    "type": "string",
                    "nullable": true,
                    "format": "uri"
                  },
                  "socialLinks": {
                    "type": "object",
                    "additionalProperties": true,
                    "nullable": true
                  },
                  "logo": {
                    "type": "string",
                    "nullable": true
                  },
                  "cuisineType": {
                    "type": "string",
                    "nullable": true
                  },
                  "seatingCapacity": {
                    "type": "integer",
                    "nullable": true,
                    "minimum": 0
                  },
                  "currency": {
                    "type": "string",
                    "nullable": true
                  },
                  "timezone": {
                    "type": "string",
                    "nullable": true
                  },
                  "locale": {
                    "type": "string",
                    "nullable": true
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created branch."
          }
        },
        "summary": "Create a branch",
        "tags": [
          "Branches"
        ]
      }
    },
    "/v1/branches/{branchId}": {
      "get": {
        "operationId": "BranchesController_get",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Branch profile."
          },
          "404": {
            "description": "Branch not found."
          }
        },
        "summary": "Get a branch",
        "tags": [
          "Branches"
        ]
      },
      "patch": {
        "operationId": "BranchesController_update",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "maxLength": 120
                  },
                  "slug": {
                    "type": "string",
                    "maxLength": 80,
                    "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
                  },
                  "status": {
                    "type": "string",
                    "enum": [
                      "active",
                      "inactive"
                    ]
                  },
                  "addressLine1": {
                    "type": "string",
                    "nullable": true
                  },
                  "addressLine2": {
                    "type": "string",
                    "nullable": true
                  },
                  "city": {
                    "type": "string",
                    "nullable": true
                  },
                  "postcode": {
                    "type": "string",
                    "nullable": true,
                    "maxLength": 16
                  },
                  "countryCode": {
                    "type": "string",
                    "maxLength": 2
                  },
                  "googlePlaceId": {
                    "type": "string",
                    "nullable": true
                  },
                  "formattedAddress": {
                    "type": "string",
                    "nullable": true
                  },
                  "lat": {
                    "type": "string",
                    "nullable": true
                  },
                  "lng": {
                    "type": "string",
                    "nullable": true
                  },
                  "phone": {
                    "type": "string",
                    "nullable": true
                  },
                  "email": {
                    "type": "string",
                    "nullable": true,
                    "format": "email"
                  },
                  "website": {
                    "type": "string",
                    "nullable": true,
                    "format": "uri"
                  },
                  "socialLinks": {
                    "type": "object",
                    "additionalProperties": true,
                    "nullable": true
                  },
                  "logo": {
                    "type": "string",
                    "nullable": true
                  },
                  "cuisineType": {
                    "type": "string",
                    "nullable": true
                  },
                  "seatingCapacity": {
                    "type": "integer",
                    "nullable": true,
                    "minimum": 0
                  },
                  "currency": {
                    "type": "string",
                    "nullable": true
                  },
                  "timezone": {
                    "type": "string",
                    "nullable": true
                  },
                  "locale": {
                    "type": "string",
                    "nullable": true
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated branch."
          }
        },
        "summary": "Update a branch",
        "tags": [
          "Branches"
        ]
      },
      "delete": {
        "operationId": "BranchesController_delete",
        "parameters": [],
        "responses": {
          "204": {
            "description": "Branch deactivated."
          }
        },
        "summary": "Deactivate a branch",
        "tags": [
          "Branches"
        ]
      }
    },
    "/v1/branches/{branchId}/set-default": {
      "post": {
        "operationId": "BranchesController_setDefault",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Default branch updated."
          }
        },
        "summary": "Set branch as default",
        "tags": [
          "Branches"
        ]
      }
    },
    "/v1/sync/pull": {
      "get": {
        "operationId": "SyncController_pull",
        "parameters": [
          {
            "name": "since",
            "required": false,
            "in": "query",
            "schema": {
              "example": "2026-05-17T10:00:00.000Z"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "WatermelonDB-compatible pull payload.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "changes",
                    "timestamp"
                  ],
                  "properties": {
                    "changes": {
                      "type": "object",
                      "properties": {
                        "businesses": {
                          "type": "object",
                          "required": [
                            "created",
                            "updated",
                            "deleted"
                          ],
                          "properties": {
                            "created": {
                              "type": "array",
                              "items": {
                                "type": "object",
                                "additionalProperties": true
                              }
                            },
                            "updated": {
                              "type": "array",
                              "items": {
                                "type": "object",
                                "additionalProperties": true
                              }
                            },
                            "deleted": {
                              "type": "array",
                              "items": {
                                "type": "string"
                              }
                            }
                          }
                        },
                        "staff_members": {
                          "type": "object",
                          "required": [
                            "created",
                            "updated",
                            "deleted"
                          ],
                          "properties": {
                            "created": {
                              "type": "array",
                              "items": {
                                "type": "object",
                                "additionalProperties": true
                              }
                            },
                            "updated": {
                              "type": "array",
                              "items": {
                                "type": "object",
                                "additionalProperties": true
                              }
                            },
                            "deleted": {
                              "type": "array",
                              "items": {
                                "type": "string"
                              }
                            }
                          }
                        }
                      }
                    },
                    "timestamp": {
                      "type": "string",
                      "format": "date-time"
                    }
                  }
                }
              }
            }
          }
        },
        "summary": "Pull POS terminal sync changes",
        "tags": [
          "Sync"
        ]
      }
    },
    "/v1/sync/push": {
      "post": {
        "operationId": "SyncController_push",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "changes"
                ],
                "properties": {
                  "changes": {
                    "type": "object",
                    "additionalProperties": true
                  },
                  "lastPulledAt": {
                    "type": "string",
                    "format": "date-time"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Push accepted.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "status"
                  ],
                  "properties": {
                    "status": {
                      "type": "string",
                      "enum": [
                        "ok"
                      ]
                    }
                  }
                }
              }
            }
          }
        },
        "summary": "Push POS terminal sync changes",
        "tags": [
          "Sync"
        ]
      }
    }
  },
  "info": {
    "title": "Quickarte API",
    "description": "",
    "version": "0.1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [
    {
      "url": "http://localhost:3001/v1"
    }
  ],
  "components": {
    "schemas": {}
  }
}
