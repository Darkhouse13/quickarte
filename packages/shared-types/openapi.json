            "schema": {
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Branch profile.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BranchResponseDto"
                }
              }
            }
          },
          "404": {
            "description": "Branch not found."
          }
        },
        "summary": "Get a branch",
        "tags": [
          "Branches"
        ]
      },
      "patch": {
        "operationId": "BranchesController_update",
        "parameters": [
          {
            "name": "branchId",
            "required": true,
            "in": "path",
            "schema": {
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
